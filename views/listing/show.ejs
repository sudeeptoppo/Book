<% layout("layout/boilerplate") %>
<div class="flex flex-col justify-center md:flex-row items-start">
  <!-- IMAGE -->
  <div class="w-full md:w-1/2 p-6 flex items-center justify-center">
    <img
      src="<%= listing.image %>"
      class="max-w-full max-h-[600px] object-contain rounded-lg"
      alt="cover"
    />
  </div>

  <!-- TEXT -->
  <div class="w-full md:w-1/2 p-8 bg-white">
    <div class="w-full flex flex-col justify-center">
      <h2 class="text-3xl font-bold mb-2"><%= listing.title %></h2>

      <p class="text-gray-500 mb-6">By <%= listing.author %></p>

      <!-- ✅ This now grows naturally -->
      <p class="text-gray-700 mb-4"><%= listing.description %></p>

      <div class="flex justify-evenly gap-4 mb-6">
        <a
          class="bg-gray-800 text-white py-2 px-4 rounded"
          href="/listings/<%= listing._id %>/edit"
          >edit</a
        >
        <form
          method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE"
        >
          <button class="bg-gray-800 text-white py-2 px-4 rounded">
            delete
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
