<% layout("layout/boilerplate") %>

    <body>
        <form method="POST" action="/listings">
            <label for="title">Title</label>
            <input type="text" name="listing[title]" id="title">
            <label for="author">Author</label>
            <input type="text" name="listing[author]" id="author">
            <label for="description">Description</label>
            <input type="text" name="listing[description]" id="description">
            <label for="image">Image</label>
            <input type="text" name="listing[image]" id="image">
            <label for="price">Price</label>
            <input type="number" name="listing[price]" id="price">
            <label for="rating">Rating</label>
            <input type="number" name="listing[rating]" id="rating">
            <button>submit</button>
        </form>
    </body>