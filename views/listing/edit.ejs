<% layout("layout/boilerplate") %>

<body>
  <div class="flex justify-center items-center">
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      novalidate
      group
      class="p-4 bg-white rounded-lg shadow hover:shadow-xl transition"
    >
      <div class="flex justify-between items-center">
        <label
          for="title"
          class="px-4 py-2.5 rounded-lg text-sm text-zinc-500 hover:bg-zinc-50"
          >Title</label
        >
        <input
          type="text"
          name="listing[title]"
          id="title"
          value="<%= listing.title %>"
          required
          class="border-2 border-zinc-500 rounded-lg p-2 shadow-lg hover:shadow-xl transition invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500 peer"
        />
        <span
          class="mt-2 hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter title
        </span>
      </div>
      <br />
      <div class="flex justify-between items-center">
        <label
          for="author"
          class="px-4 py-2.5 rounded-lg text-sm text-zinc-500 hover:bg-zinc-50"
          >Author</label
        >
        <input
          type="text"
          name="listing[author]"
          id="author"
          value="<%= listing.author %>"
          required
          class="border-2 border-zinc-500 rounded-lg p-2 shadow-lg hover:shadow-xl transition invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500 peer"
        />
        <span
          class="mt-2 hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter author
        </span>
      </div>
      <br />
      <div class="flex justify-between items-center">
        <label
          for="description"
          class="px-4 py-2.5 rounded-lg text-sm text-zinc-500 hover:bg-zinc-50"
          >Description</label
        >
        <input
          type="text"
          name="listing[description]"
          id="description"
          value="<%= listing.description %>"
          required
          class="border-2 border-zinc-500 rounded-lg p-2 shadow-lg hover:shadow-xl transition invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500 peer"
        />
        <span
          class="mt-2 hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter description
        </span>
      </div>
      <br />
      <div class="flex justify-between items-center">
        <label
          for="image"
          class="px-4 py-2.5 rounded-lg text-sm text-zinc-500 hover:bg-zinc-50"
          >Image</label
        >
        <input
          type="text"
          name="listing[image]"
          id="image"
          value="<%= listing.image %>"
          required
          class="border-2 border-zinc-500 rounded-lg p-2 shadow-lg hover:shadow-xl transition invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500 peer"
        />
        <span
          class="mt-2 hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter image URL
        </span>
      </div>
      <br />
      <div class="flex justify-between items-center">
        <label
          for="price"
          class="px-4 py-2.5 rounded-lg text-sm text-zinc-500 hover:bg-zinc-50"
          >Price</label
        >
        <input
          type="number"
          name="listing[price]"
          id="price"
          value="<%= listing.price %>"
          required
          class="border-2 border-zinc-500 rounded-lg p-2 shadow-lg hover:shadow-xl transition invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500 peer"
        />
        <span
          class="mt-2 hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter price
        </span>
      </div>
      <br />
      <div class="flex justify-between items-center">
        <label
          for="rating"
          class="px-4 py-2.5 rounded-lg text-sm text-zinc-500 hover:bg-zinc-50"
          >Rating</label
        >
        <input
          type="number"
          name="listing[rating]"
          id="rating"
          required
          value="<%= listing.rating %>"
          class="border-2 border-zinc-500 rounded-lg p-2 shadow-lg hover:shadow-xl transition invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500 peer"
        />
        <span
          class="mt-2 hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter rating
        </span>
      </div>
      <br />
      <div class="flex justify-center items-center">
        <button
          class="bg-zinc-500 text-white px-4 py-2 rounded-full group-invalid:pointer-events-none group-invalid:opacity-30"
        >
          Add
        </button>
      </div>
    </form>
  </div>
</body>
