<% layout("layout/boilerplate") %>

<body>
  <div class="flex justify-center items-center min-h-screen">
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=PUT"
      novalidate
      class="group p-6 bg-white rounded-lg shadow w-full max-w-lg space-y-4"
    >
      <!-- Title -->
      <div>
        <label class="text-sm text-zinc-500">Title</label>
        <input
          type="text"
          name="listing[title]"
          id="title"
          value="<%= listing.title %>"
          placeholder=" "
          required
          class="w-full border-2 border-zinc-300 rounded-lg p-2 mt-1 peer invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
        />
        <span
          class="hidden text-sm text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter title
        </span>
      </div>

      <!-- Author -->
      <div>
        <label class="text-sm text-zinc-500">Author</label>
        <input
          type="text"
          name="listing[author]"
          value="<%= listing.author %>"
          placeholder=" "
          required
          class="w-full border-2 border-zinc-300 rounded-lg p-2 mt-1 peer invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
        />
        <span
          class="hidden text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter author
        </span>
      </div>

      <!-- Description -->
      <div>
        <label class="text-sm text-zinc-500">Description</label>
        <input
          type="text"
          name="listing[description]"
          value="<%= listing.description %>"
          placeholder=" "
          required
          class="w-full border-2 border-zinc-300 rounded-lg p-2 mt-1 peer invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
        />
        <span
          class="hidden text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter description
        </span>
      </div>

      <!-- image url -->
      <div>
        <label class="text-sm text-zinc-500">Image URL</label>
        <input
          type="text"
          name="listing[image]"
          value="<%= listing.image %>"
          placeholder=" "
          required
          class="w-full border-2 border-zinc-300 rounded-lg p-2 mt-1 peer invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
        />
        <span
          class="hidden text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter image URL
        </span>
      </div>

      <!-- Price -->
      <div>
        <label class="text-sm text-zinc-500">Price</label>
        <input
          type="number"
          name="listing[price]"
          value="<%= listing.price %>"
          placeholder=" "
          required
          class="w-full border-2 border-zinc-300 rounded-lg p-2 mt-1 peer invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
        />
        <span
          class="hidden text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter price
        </span>
      </div>

      <!-- Rating -->
      <div>
        <label class="text-sm text-zinc-500">Rating</label>
        <input
          type="number"
          name="listing[rating]"
          value="<%= listing.rating %>"
          placeholder=" "
          required
          class="w-full border-2 border-zinc-300 rounded-lg p-2 mt-1 peer invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
        />
        <span
          class="hidden text-red-500 peer-[&:not(:placeholder-shown):not(:focus):invalid]:block"
        >
          Please enter rating
        </span>
      </div>

      <!-- Button -->
      <button
        type="submit"
        class="bg-zinc-900 text-white px-6 py-2 rounded-full group-invalid:pointer-events-none group-invalid:opacity-30"
      >
        Update
      </button>
    </form>
  </div>
</body>
```
