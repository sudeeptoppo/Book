<% layout("layout/boilerplate") %>

    <body>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
            <label for="title">Title</label>
            <input type="text" name="listing[title]" id="title" value="<%= listing.title %>">
            <label for="author">Author</label>
            <input type="text" name="listing[author]" id="author" value="<%= listing.author %>">
            <label for="description">Description</label>
            <input type="text" name="listing[description]" id="description" value="<%= listing.description %>">
            <label for="image">Image</label>
            <input type="text" name="listing[image]" id="image" value="<%= listing.image %>">
            <label for="price">Price</label>
            <input type="number" name="listing[price]" id="price" value="<%= listing.price %>">
            <label for="rating">Rating</label>
            <input type="number" name="listing[rating]" id="rating" value="<%= listing.rating %>">
            <button>submit</button>
        </form>
    </body>