<nav
  class="w-full flex items-center justify-between px-10 md:px-20 py-6 bg-white"
>
  <!-- Logo -->
  <div
    class="text-[#c58c6d] text-2xl tracking-[0.3em]"
    style="font-family: &quot;Bebas Neue&quot;, sans-serif"
  >
    LOGO
  </div>

  <!-- Menu -->
  <ul
    class="hidden md:flex space-x-16 text-[#c58c6d] text-xl tracking-[0.25em] uppercase"
    style="font-family: &quot;Bebas Neue&quot;, sans-serif"
  >
    <li class="text-[#e0b04b] cursor-pointer transition-colors duration-300">
      HOME
    </li>

    <li
      class="hover:text-[#e0b04b] cursor-pointer transition-colors duration-300"
    >
      SERVICES
    </li>

    <li
      class="hover:text-[#e0b04b] cursor-pointer transition-colors duration-300"
    >
      NEWS
    </li>

    <li
      class="hover:text-[#e0b04b] cursor-pointer transition-colors duration-300"
    >
      CONTACT
    </li>

    <li
      class="hover:text-[#e0b04b] cursor-pointer transition-colors duration-300"
    >
      ABOUT
    </li>
  </ul>

  <!-- ✅ RIGHT SIDE (ADDED) -->
  <div class="hidden md:flex items-center space-x-6">
    <!-- Search -->
    <div
      class="flex items-center border border-[#c58c6d] rounded-full px-3 py-1"
    >
      <input
        type="text"
        placeholder="Search"
        class="outline-none bg-transparent text-[#c58c6d] placeholder-[#c58c6d] text-sm w-24"
      />
      <i class="fa-solid fa-magnifying-glass text-[#c58c6d]"></i>
    </div>

    <% if (!currentUser) { %>
      <!-- Sign In -->
      <a
        href="/login"
        class="text-[#c58c6d] hover:text-[#e0b04b] transition-colors duration-300 uppercase tracking-[0.2em]"
        style="font-family: &quot;Bebas Neue&quot;, sans-serif"
      >
        SIGN IN
      </a>
    <% } else { %>
      <!-- Logout -->
      <form action="/logout" method="POST">
        <button
          class="text-[#c58c6d] hover:text-[#e0b04b] transition-colors duration-300 uppercase tracking-[0.2em]"
          style="font-family: &quot;Bebas Neue&quot;, sans-serif"
        >
          LOGOUT
        </button>
      </form>
    <% } %>

    

    
  </div>

  <!-- Mobile Menu Button -->
  <button id="menuBtn" class="md:hidden text-[#c58c6d] text-3xl">⋮</button>

  <!-- Mobile Dropdown -->
  <ul
    id="mobileMenu"
    class="absolute top-full right-10 mt-4 w-56 bg-white shadow-lg rounded-lg text-[#c58c6d] uppercase text-lg space-y-4 p-6 opacity-0 scale-95 pointer-events-none transition-all duration-300"
    style="
      font-family: &quot;Bebas Neue&quot;, sans-serif;
      letter-spacing: 0.2em;
    "
  >
    <li class="text-[#e0b04b]">HOME</li>
    <li class="hover:text-[#e0b04b]">SERVICES</li>
    <li class="hover:text-[#e0b04b]">NEWS</li>
    <li class="hover:text-[#e0b04b]">CONTACT</li>
    <li class="hover:text-[#e0b04b]">ABOUT</li>

    <!-- ✅ Added for mobile -->
    <li>
      <input
        type="text"
        placeholder="Search"
        class="w-full border border-[#c58c6d] rounded-full px-3 py-1 outline-none text-sm"
      />
    </li>

    <li class="hover:text-[#e0b04b]">
      <a href="/login">SIGN IN</a>
    </li>

    <li>
      <form action="/logout" method="POST">
        <button class="hover:text-[#e0b04b]">LOGOUT</button>
      </form>
    </li>
  </ul>
</nav>
